<Window x:Class="WEVG.ResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WEVG"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Pill-shaped buttons with hover feedback -->
        <Style x:Key="Pill" TargetType="Button">
            <Setter Property="Foreground" Value="#FFE8E8F0"/>
            <Setter Property="Background" Value="#FF2A2A35"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PillPrimary" TargetType="Button" BasedOn="{StaticResource Pill}">
            <Setter Property="Background" Value="#FF4F6BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <!-- Outer margin leaves room for the drop shadow -->
    <Border Background="#FF1B1B22" CornerRadius="14" Margin="16"
            BorderBrush="#FF33333F" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="28" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>

        <StackPanel Width="360" Margin="26,24,26,22">

            <!-- Accent badge -->
            <Border Width="52" Height="52" CornerRadius="26" HorizontalAlignment="Left"
                    Background="#3322C55E" Margin="0,0,0,16">
                <TextBlock x:Name="Glyph" Text="✓" FontSize="26" FontWeight="Bold"
                           Foreground="#FF34D27B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="TitleText" Text="Done" FontSize="18" FontWeight="SemiBold"
                       Foreground="#FFF2F2F7" TextWrapping="Wrap"/>
            <TextBlock x:Name="MessageText" Text="" FontSize="13" Foreground="#FF9A9AB0"
                       TextWrapping="Wrap" Margin="0,6,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="SecondaryButton" Content="Close" Style="{StaticResource Pill}"
                        Click="Secondary_Click" Margin="0,0,10,0"/>
                <Button x:Name="PrimaryButton" Content="Open folder" Style="{StaticResource PillPrimary}"
                        Click="Primary_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
